{
  "expo": {
    "name": "expo-template",
    "slug": "expo-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dhruvv25.expotemplate",
      "ndkVersion": "25.2.9519653"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "dhruvv2567",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "hermesEnabled": true,
            "kotlinVersion": "1.9.24",
            "gradleJVMArgs": "-Xmx4096m -XX:MaxMetaspaceSize=512m"
          }
        }
      ],
      "./plugins/android-fixes.js",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "80294e4d-b6b9-4a6a-b906-7880ae75e859"
      }
    }
  }
}
